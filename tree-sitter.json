{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "cel",
      "camelcase": "CEL",
      "scope": "source.cel",
      "path": ".",
      "file-types": [
        "cel"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "Apache-2.0",
    "description": "Common Expression Language (CEL) grammar for tree-sitter",
    "authors": [
      {
        "name": "Buf Technologies, Inc."
      }
    ],
    "links": {
      "repository": "https://github.com/bufbuild/tree-sitter-cel"
    }
  },
  "bindings": {
    "c": true,
    "node": true,
    "rust": true
  }
}
